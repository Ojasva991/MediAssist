# Copy this file to .env and fill in real values.
# Never commit your actual .env file.

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use for triage analysis
GEMINI_MODEL=gemini-2.0-flash

APP_NAME=MediAssist AI
ENVIRONMENT=development

# Postgres connection string. Free options: Supabase, Neon, Render Postgres.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=your-postgres-connection-string-here

# Any long random string - used to sign login tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-random-secret-here

# Comma-separated list of frontend origins allowed to call this API.
ALLOWED_ORIGINS=https://medi-assist-nu.vercel.app,http://localhost:5173
